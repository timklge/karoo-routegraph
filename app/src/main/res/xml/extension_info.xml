<?xml version="1.0" encoding="utf-8"?>
<ExtensionInfo
    displayName="@string/extension_name"
    icon="@drawable/trip"
    id="karoo-routegraph"
    scansDevices="false"
    mapLayer="true">

    <DataType
        description="@string/routegraph_description"
        displayName="@string/routegraph"
        graphical="true"
        icon="@drawable/chart"
        typeId="routegraph" />

    <DataType
        description="@string/verticalroutegraph_description"
        displayName="@string/verticalroutegraph"
        graphical="true"
        icon="@drawable/trip"
        typeId="verticalroutegraph" />

    <DataType
        description="@string/distance_to_poi_description"
        displayName="@string/distance_to_poi"
        graphical="false"
        icon="@drawable/trip"
        typeId="distancetopoi" />

    <DataType
        description="@string/elevation_to_poi_description"
        displayName="@string/elevation_to_poi"
        graphical="false"
        icon="@drawable/trip"
        typeId="elevationtopoi" />

    <DataType
        description="@string/etapoi_description"
        displayName="@string/etapoi"
        graphical="false"
        icon="@drawable/trip"
        typeId="etapoi" />

    <DataType
        description="@string/eta_description"
        displayName="@string/eta"
        graphical="false"
        icon="@drawable/trip"
        typeId="eta" />

    <DataType
        description="@string/poi_button_description"
        displayName="@string/poi_button"
        graphical="true"
        icon="@drawable/trip"
        typeId="poiButton" />

    <DataType
        description="@string/poi_list_ahead_description"
        displayName="@string/poi_list_ahead"
        graphical="true"
        icon="@drawable/trip"
        typeId="poilistahead" />

</ExtensionInfo>
